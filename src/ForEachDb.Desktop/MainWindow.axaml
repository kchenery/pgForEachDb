<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ForEachDb.Desktop.ViewModels"
        xmlns:views="clr-namespace:ForEachDb.Desktop.Views"
        x:Class="ForEachDb.Desktop.MainWindow"
        x:DataType="vm:ShellViewModel"
        Title="pgForEachDb"
        Icon="avares://ForEachDb.Desktop/Assets/logo.png"
        Width="1100" Height="720"
        MinWidth="800" MinHeight="500">
  <Window.DataTemplates>
    <DataTemplate DataType="vm:ConnectionViewModel">
      <views:ConnectionView />
    </DataTemplate>
    <DataTemplate DataType="vm:WorkspaceViewModel">
      <views:WorkspaceView />
    </DataTemplate>
  </Window.DataTemplates>

  <ContentControl Content="{Binding Current}" />
</Window>

<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:ForEachDb.Console.ViewModels"
        xmlns:views="clr-namespace:ForEachDb.Console.Views"
        x:Class="ForEachDb.Console.MainWindow"
        x:DataType="vm:ShellViewModel"
        Title="pgForEachDb">
  <Window.DataTemplates>
    <DataTemplate DataType="vm:ConnectionViewModel">
      <views:ConnectionView />
    </DataTemplate>
    <DataTemplate DataType="vm:WorkspaceViewModel">
      <views:WorkspaceView />
    </DataTemplate>
  </Window.DataTemplates>

  <ContentControl Content="{Binding Current}" />
</Window>

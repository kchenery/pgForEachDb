<Application xmlns="https://github.com/avaloniaui"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:console="https://github.com/jinek/consolonia"
             xmlns:dg="clr-namespace:Consolonia.Controls.DataGrid;assembly=Consolonia.Controls.DataGrid"
             x:Class="ForEachDb.Console.App"
             RequestedThemeVariant="Default">
    <Application.Styles>
        <console:ModernTheme />
        <dg:AutoDataGridStyles />
    </Application.Styles>
</Application>
